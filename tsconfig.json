{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom"],
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["js/**/*.ts", "js/**/*.tsx", "shared/**/*.ts", "tests/**/*.ts", "global.d.ts"]
}
